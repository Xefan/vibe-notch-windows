<Application x:Class="ClaudeIslandWindows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ClaudeIslandWindows.Views"
             Startup="OnStartup">
    <Application.Resources>
        <views:PhaseColorConverter x:Key="PhaseColorConverter" />
        <views:PhaseTextConverter x:Key="PhaseTextConverter" />
        <views:ApprovalVisibilityConverter x:Key="ApprovalVisConverter" />
        <views:ContentVisibilityConverter x:Key="ContentVisibility" />
        <views:GreaterThanZeroConverter x:Key="GreaterThanZero" />
        <views:EmptyVisibilityConverter x:Key="EmptyVisibility" />
        <views:NullOrEmptyToCollapsedConverter x:Key="NullOrEmptyVis" />
        <views:PhaseSpinnerConverter x:Key="PhaseSpinnerConverter" />
        <views:SpinnerVisibilityConverter x:Key="SpinnerVisConverter" />
        <views:DotVisibilityConverter x:Key="DotVisConverter" />

        <!-- Minimal scrollbar: small grey handle, no track. Vertical-only (this app has no horizontal scrollers). -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Margin="0,8,0,24">
                            <!-- Orientation must be explicit; default is Horizontal which breaks thumb tracking on a vertical scrollbar.
                                 IsDirectionReversed=True is correct for vertical: Track Value 0 maps to thumb at top. -->
                            <Track x:Name="PART_Track"
                                   Orientation="Vertical"
                                   IsDirectionReversed="True"
                                   ViewportSize="{TemplateBinding ViewportSize}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#505050"
                                                        CornerRadius="2"
                                                        MinHeight="30"
                                                        Margin="1,0" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu row hover style -->
        <Style x:Key="MenuRowBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Global button style: black bg, no border, grey bg+border on hover -->
        <Style x:Key="NotchButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1A" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252525" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card button: always shows card bg, lighter on hover -->
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="BorderBrush" Value="#2A2A2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#222222" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
