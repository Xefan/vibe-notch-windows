<UserControl x:Class="ClaudeIslandWindows.Views.NotchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ClaudeIslandWindows.ViewModels"
             xmlns:controls="clr-namespace:ClaudeIslandWindows.Controls"
             x:Name="Root"
             Width="600" Height="580">

    <!-- Content grid at full expanded size. A Clip geometry masks it to the notch shape. -->
    <!-- Shadow wrapper: effect here renders shadow of the clipped content shape -->
    <Grid x:Name="ShadowWrapper"
          HorizontalAlignment="Center"
          VerticalAlignment="Top">

        <Grid x:Name="ContentGrid"
              Width="480" Height="320"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Background="Transparent">
        <Grid.Clip>
            <!-- Initial small clip, overridden by code-behind -->
            <RectangleGeometry Rect="142,0,196,32" RadiusX="12" RadiusY="12" />
        </Grid.Clip>

        <!-- Black background (only visible within clip) -->
        <Rectangle Fill="#000000" />

        <Grid Margin="14,4,14,4" ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header row -->
            <Grid Grid.Row="0" x:Name="HeaderRow"
                  Background="Transparent"
                  MouseLeftButtonDown="OnHeaderClick"
                  Cursor="Hand">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <controls:CrabIcon x:Name="CrabIcon" Grid.Column="0"
                                   Width="18" Height="14"
                                   VerticalAlignment="Center" Margin="4,0,4,0"
                                   RenderTransformOrigin="0.5,0.5">
                    <controls:CrabIcon.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CrabScale" ScaleX="0" ScaleY="0" />
                            <TranslateTransform x:Name="CrabTranslate" X="0" />
                        </TransformGroup>
                    </controls:CrabIcon.RenderTransform>
                </controls:CrabIcon>

                <Grid Grid.Column="1" />

                <TextBlock x:Name="SpinnerText" Grid.Column="2"
                           FontFamily="Segoe UI Symbol"
                           FontSize="12" FontWeight="Bold"
                           Foreground="#D9784F"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Width="14" Margin="0,0,8,0"
                           Visibility="Collapsed">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="SpinnerTranslate" X="0" />
                    </TextBlock.RenderTransform>
                </TextBlock>

                <Button x:Name="MenuButton" Grid.Column="3"
                        Command="{Binding ToggleMenuCommand}"
                        Style="{StaticResource NotchButton}"
                        Foreground="#A0A0A0" FontSize="14"
                        Padding="4,2" VerticalAlignment="Center"
                        Content="&#x2026;"
                        Visibility="Collapsed" />
            </Grid>

            <!-- Content area -->
            <Grid Grid.Row="1" x:Name="ContentArea" Opacity="0" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding CurrentContent, Converter={StaticResource ContentVisibility}, ConverterParameter=Instances}">
                    <ItemsControl ItemsSource="{Binding Sessions}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8"
                                        Margin="0,2" Padding="8,6"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="OnSessionRowClick"
                                        Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1A1A1A" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <controls:SpinnerText Grid.Column="0"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                   Foreground="{Binding Phase, Converter={StaticResource PhaseColorConverter}}"
                                                   Visibility="{Binding Phase, Converter={StaticResource SpinnerVisConverter}}" />
                                        <Ellipse Grid.Column="0" Width="6" Height="6"
                                                 VerticalAlignment="Center" Margin="4,0,12,0"
                                                 Fill="{Binding Phase, Converter={StaticResource PhaseColorConverter}}"
                                                 Visibility="{Binding Phase, Converter={StaticResource DotVisConverter}}" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProjectName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#E0E0E0" />
                                            <TextBlock Text="{Binding Phase, Converter={StaticResource PhaseTextConverter}}"
                                                       FontSize="11" Foreground="#707070" />
                                            <!-- Surfaced by hook events PostToolUseFailure / PermissionDenied / StopFailure.
                                                 Cleared on UserPromptSubmit/SessionStart so it can't linger past recovery. -->
                                            <TextBlock Text="{Binding LastError}"
                                                       FontSize="11" Foreground="#EE9090"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding LastError, Converter={StaticResource NullOrEmptyVis}}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding Phase, Converter={StaticResource ApprovalVisConverter}}">
                                            <Button Content="Allow" Margin="0,0,4,0"
                                                    Style="{StaticResource NotchButton}"
                                                    Foreground="#90EE90"
                                                    Padding="8,4" FontSize="11"
                                                    Command="{Binding DataContext.ApprovePermissionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Deny"
                                                    Style="{StaticResource NotchButton}"
                                                    Foreground="#EE9090"
                                                    Padding="8,4" FontSize="11"
                                                    Command="{Binding DataContext.DenyPermissionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Visibility="{Binding CurrentContent, Converter={StaticResource ContentVisibility}, ConverterParameter=Instances}">
                    <TextBlock Text="No active Claude sessions"
                               Foreground="#404040" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding Sessions.Count, Converter={StaticResource EmptyVisibility}}"
                               IsHitTestVisible="False" />
                </Grid>

                <ScrollViewer Margin="0,4,0,0" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding CurrentContent, Converter={StaticResource ContentVisibility}, ConverterParameter=Menu}">
                    <StackPanel Margin="0,0,6,0">

                        <!-- Notification Sound -->
                        <Border x:Name="SoundRow" CornerRadius="8" Padding="12,10"
                                Margin="0,2" Cursor="Hand"
                                MouseLeftButtonDown="OnSoundRowClick"
                                Style="{StaticResource MenuRowBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Notification Sound"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                                <TextBlock x:Name="SoundChevron" Grid.Column="2"
                                           Text="&#x203A;" FontSize="14"
                                           Foreground="#66FFFFFF" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <Border x:Name="SoundPickerPanel" Visibility="Collapsed"
                                Margin="0,0,0,2">
                            <ScrollViewer MaxHeight="192" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="SoundList" />
                            </ScrollViewer>
                        </Border>

                        <!-- Launch at Login -->
                        <Border x:Name="LaunchRow" CornerRadius="8" Padding="12,10"
                                Margin="0,2" Cursor="Hand"
                                MouseLeftButtonDown="OnLaunchAtLoginClick"
                                Style="{StaticResource MenuRowBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Launch at Login"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Ellipse x:Name="LaunchDot" Width="6" Height="6"
                                             Fill="#66FFFFFF" Margin="0,0,6,0" />
                                    <TextBlock x:Name="LaunchLabel" Text="Off"
                                               FontSize="11" Foreground="#66FFFFFF" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Hooks -->
                        <Border x:Name="HooksRow" CornerRadius="8" Padding="12,10"
                                Margin="0,2" Cursor="Hand"
                                MouseLeftButtonDown="OnHooksToggleClick"
                                Style="{StaticResource MenuRowBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Hooks"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Ellipse x:Name="HooksDot" Width="6" Height="6"
                                             Fill="#4CAF50" Margin="0,0,6,0" />
                                    <TextBlock x:Name="HooksLabel" Text="On"
                                               FontSize="11" Foreground="#66FFFFFF" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Claude Buddy (BLE) -->
                        <Border x:Name="BuddyRow" CornerRadius="8" Padding="12,10"
                                Margin="0,2" Cursor="Hand"
                                MouseLeftButtonDown="OnBuddyReconnectClick"
                                Style="{StaticResource MenuRowBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE702;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Claude Buddy"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="#B3FFFFFF" />
                                    <TextBlock x:Name="BuddyDevice"
                                               Text="(not connected)"
                                               FontSize="11" Foreground="#66FFFFFF" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Ellipse x:Name="BuddyDot" Width="6" Height="6"
                                             Fill="#66FFFFFF" Margin="0,0,6,0" />
                                    <TextBlock x:Name="BuddyLabel" Text="Off"
                                               FontSize="11" Foreground="#66FFFFFF" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Divider -->
                        <Border Height="1" Background="#14FFFFFF" Margin="0,6" />

                        <!-- Star on GitHub -->
                        <Border CornerRadius="8" Padding="12,10"
                                Margin="0,2" Cursor="Hand"
                                MouseLeftButtonDown="OnStarGitHubClick"
                                Style="{StaticResource MenuRowBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Star on GitHub"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="#B3FFFFFF" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Version info -->
                        <Border CornerRadius="8" Padding="12,8" Margin="0,2">
                            <StackPanel>
                                <TextBlock Text="Claude Island for Windows"
                                           FontSize="12" Foreground="#66808080" />
                                <TextBlock Text="v1.0.0"
                                           FontSize="11" Foreground="#505050" />
                            </StackPanel>
                        </Border>

                        <!-- Divider -->
                        <Border Height="1" Background="#14FFFFFF" Margin="0,6" />

                        <!-- Quit -->
                        <Border CornerRadius="8" Padding="12,10"
                                Margin="0,2" Cursor="Hand"
                                MouseLeftButtonDown="OnQuitClick"
                                Style="{StaticResource MenuRowBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#FF6666" VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Quit Claude Island"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="#FF6666" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <Grid Margin="0,4,0,0"
                      Visibility="{Binding CurrentContent, Converter={StaticResource ContentVisibility}, ConverterParameter=Chat}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Margin="0,0,0,4"
                            Style="{StaticResource NotchButton}"
                            HorizontalContentAlignment="Stretch"
                            Command="{Binding ExitChatCommand}">
                        <Grid>
                            <TextBlock Text="&#x2190;"
                                       FontSize="13" Foreground="#606060"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CurrentChatSession.ProjectName}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#E0E0E0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <ScrollViewer x:Name="ChatScroller" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16,0,16,16">
                        <StackPanel x:Name="ChatMessages" Margin="0,0,6,0" />
                    </ScrollViewer>

                    <Border x:Name="ChatApprovalBar" Grid.Row="2"
                            Background="Transparent" CornerRadius="8"
                            Padding="8,6" Margin="0,4,0,0"
                            BorderBrush="Transparent" BorderThickness="1"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ApprovalToolName" Grid.Column="0"
                                       FontSize="12" Foreground="#FFB400"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Allow" Margin="4,0"
                                    Style="{StaticResource NotchButton}"
                                    Foreground="#90EE90"
                                    Padding="10,4" FontSize="11"
                                    Click="OnChatApprove" />
                            <Button Grid.Column="2" Content="Deny"
                                    Style="{StaticResource NotchButton}"
                                    Foreground="#EE9090"
                                    Padding="10,4" FontSize="11"
                                    Click="OnChatDeny" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>

        <!-- Hover/click target matching visible notch area -->
        <Border x:Name="HitTarget"
                Width="196" Height="32"
                Background="Transparent"
                HorizontalAlignment="Center"
                VerticalAlignment="Top" />
    </Grid>
</UserControl>
