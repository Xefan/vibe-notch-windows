<UserControl x:Class="ClaudeIslandWindows.Views.NotchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ClaudeIslandWindows.ViewModels"
             x:Name="Root"
             ClipToBounds="False"
             Width="196" Height="32">

    <Grid>
        <!-- Notch shape background -->
        <Border x:Name="NotchBorder"
                Background="#000000"
                CornerRadius="0,0,14,14">
            <Border.Effect>
                <DropShadowEffect x:Name="Shadow"
                                  ShadowDepth="0" Opacity="0.4"
                                  BlurRadius="12" Color="#000000" />
            </Border.Effect>
        </Border>

        <!-- Content -->
        <Grid Margin="8,4,8,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header row -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status dot (only visible when there's activity) -->
                <Ellipse x:Name="StatusDot" Grid.Column="0" Width="8" Height="8"
                         VerticalAlignment="Center" Margin="0,0,6,0" Fill="#808080"
                         Visibility="Collapsed" />

                <!-- Spacer -->
                <Grid Grid.Column="1" />

                <!-- Menu button (visible when opened) -->
                <Button x:Name="MenuButton" Grid.Column="2"
                        Command="{Binding ToggleMenuCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="#A0A0A0" FontSize="14"
                        Padding="4,2" VerticalAlignment="Center"
                        Content="&#x2026;" Cursor="Hand"
                        Visibility="Collapsed">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}"
                                    Cursor="Hand">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content area (visible when opened) -->
            <Grid Grid.Row="1" x:Name="ContentArea" Opacity="0" Visibility="Collapsed">
                <!-- Instances list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding CurrentContent, Converter={StaticResource ContentVisibility}, ConverterParameter=Instances}">
                    <ItemsControl ItemsSource="{Binding Sessions}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A1A" CornerRadius="8"
                                        Margin="0,2" Padding="8,6"
                                        BorderBrush="#2A2A2A" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="8" Height="8"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Fill="{Binding Phase, Converter={StaticResource PhaseColorConverter}}" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProjectName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#E0E0E0" />
                                            <TextBlock Text="{Binding Phase, Converter={StaticResource PhaseTextConverter}}"
                                                       FontSize="11" Foreground="#707070" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding Phase, Converter={StaticResource ApprovalVisConverter}}">
                                            <Button Content="Allow" Margin="0,0,4,0"
                                                    Background="#2D5A27" Foreground="#90EE90"
                                                    Padding="8,4" FontSize="11"
                                                    Command="{Binding DataContext.ApprovePermissionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Deny"
                                                    Background="#5A2727" Foreground="#EE9090"
                                                    Padding="8,4" FontSize="11"
                                                    Command="{Binding DataContext.DenyPermissionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <TextBlock Text="No active Claude sessions"
                           Foreground="#404040" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding Sessions.Count, Converter={StaticResource EmptyVisibility}}" />

                <!-- Menu -->
                <StackPanel Margin="0,8,0,0"
                            Visibility="{Binding CurrentContent, Converter={StaticResource ContentVisibility}, ConverterParameter=Menu}">
                    <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold"
                               Foreground="#E0E0E0" Margin="0,0,0,8" />
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="12,10"
                            BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="Claude Code Hooks" FontSize="13" Foreground="#D0D0D0" />
                            <TextBlock Text="Monitor sessions via hook events"
                                       FontSize="11" Foreground="#606060" />
                        </StackPanel>
                    </Border>
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="12,10"
                            BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="Claude Island for Windows" FontSize="12" Foreground="#808080" />
                            <TextBlock Text="v1.0.0" FontSize="11" Foreground="#505050" />
                        </StackPanel>
                    </Border>
                    <Button x:Name="QuitButton" Content="Quit Claude Island"
                            HorizontalAlignment="Stretch"
                            Background="#1A1A1A" Foreground="#CC4444"
                            BorderBrush="#2A2A2A" BorderThickness="1"
                            Padding="12,10" FontSize="13"
                            Cursor="Hand" Click="OnQuitClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}"
                                        Cursor="Hand">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
